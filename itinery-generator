import React, { useState, useMemo, useCallback } from "react";
import {
  Sparkles, MapPin, Clock, IndianRupee, RotateCcw, ThumbsUp, Trash2,
  Plus, Save, Utensils, Route, Brain, ChevronDown, Star,
} from "lucide-react";

// ---------------------------------------------------------------------------
// This is a front-end prototype. All "AI" here is a transparent, deterministic
// content-based scorer + greedy route grouping running client-side over a
// mock dataset — no LLM call, no backend. See ARCHITECTURE NOTES at the
// bottom for how this maps onto a real recommendation service.
// ---------------------------------------------------------------------------

const DESTINATIONS = [
  { id: 1, name: "Amber Fort", state: "Rajasthan", category: "Heritage", budget: "Mid", season: "Winter", rating: 4.7, time: "3h" },
  { id: 2, name: "City Palace, Jaipur", state: "Rajasthan", category: "Heritage", budget: "Mid", season: "Winter", rating: 4.5, time: "2h" },
  { id: 3, name: "Jaisalmer Desert Safari", state: "Rajasthan", category: "Adventure", budget: "Mid", season: "Winter", rating: 4.6, time: "4h" },
  { id: 4, name: "Lake Pichola, Udaipur", state: "Rajasthan", category: "Heritage", budget: "High", season: "Winter", rating: 4.6, time: "2h" },
  { id: 5, name: "Munnar Tea Gardens", state: "Kerala", category: "Hill Station", budget: "Mid", season: "Winter", rating: 4.6, time: "3h" },
  { id: 6, name: "Alleppey Backwaters", state: "Kerala", category: "Beach", budget: "Mid", season: "Winter", rating: 4.5, time: "5h" },
  { id: 7, name: "Wayanad Wildlife Sanctuary", state: "Kerala", category: "Wildlife", budget: "Low", season: "Winter", rating: 4.3, time: "4h" },
  { id: 8, name: "Manali Mall Road + Hadimba Temple", state: "Himachal Pradesh", category: "Hill Station", budget: "Mid", season: "Summer", rating: 4.4, time: "2h" },
  { id: 9, name: "Solang Valley", state: "Himachal Pradesh", category: "Adventure", budget: "Mid", season: "Summer", rating: 4.5, time: "4h" },
  { id: 10, name: "Baga Beach", state: "Goa", category: "Beach", budget: "Mid", season: "Winter", rating: 4.3, time: "3h" },
  { id: 11, name: "Old Goa Churches", state: "Goa", category: "Heritage", budget: "Low", season: "Winter", rating: 4.4, time: "2h" },
  { id: 12, name: "Rishikesh Rafting", state: "Uttarakhand", category: "Adventure", budget: "Low", season: "Winter", rating: 4.6, time: "3h" },
  { id: 13, name: "Ram Jhula + Ganga Aarti", state: "Uttarakhand", category: "Spiritual", budget: "Low", season: "Winter", rating: 4.7, time: "2h" },
  { id: 14, name: "Ranthambore Safari", state: "Rajasthan", category: "Wildlife", budget: "High", season: "Winter", rating: 4.5, time: "4h" },
  { id: 15, name: "Varanasi Ghats", state: "Uttar Pradesh", category: "Spiritual", budget: "Low", season: "Winter", rating: 4.6, time: "3h" },
  { id: 16, name: "Kasol Trek", state: "Himachal Pradesh", category: "Adventure", budget: "Low", season: "Summer", rating: 4.4, time: "5h" },
];

const CATEGORIES = ["Heritage", "Hill Station", "Beach", "Wildlife", "Spiritual", "Adventure"];
const FOOD_BY_STATE = {
  Rajasthan: "Try dal baati churma for dinner tonight.",
  Kerala: "Don't miss a Kerala sadya thali for lunch.",
  "Himachal Pradesh": "Warm up with siddu and local trout.",
  Goa: "Fish curry rice at a beach shack is a must.",
  Uttarakhand: "Grab kumaoni raita and bal mithai.",
  "Uttar Pradesh": "Street-side kachori sabzi near the ghats.",
};
const BUDGET_ORDER = ["Low", "Mid", "High"];
const PACE = { Relaxed: 2, Balanced: 3, Packed: 4 };

let idc = 500;
const nid = () => `it-${idc++}`;

export default function ItineraryGenerator() {
  const [prefs, setPrefs] = useState({
    duration: 4, budget: "Mid", categories: ["Heritage", "Adventure"], pace: "Balanced", season: "Winter",
  });
  const [profile, setProfile] = useState({
    Heritage: 8, Beach: 5, Wildlife: 2, "Hill Station": 6, Spiritual: 3, Adventure: 4,
  });
  const [itinerary, setItinerary] = useState(null);
  const [seed, setSeed] = useState(0);
  const [saved, setSaved] = useState([]);
  const [learnFlash, setLearnFlash] = useState(null);

  const weights = useMemo(() => {
    const total = Object.values(profile).reduce((a, b) => a + b, 0) || 1;
    const w = {};
    Object.entries(profile).forEach(([k, v]) => (w[k] = v / total));
    return w;
  }, [profile]);

  function toggleCategory(c) {
    setPrefs((p) => ({
      ...p,
      categories: p.categories.includes(c) ? p.categories.filter((x) => x !== c) : [...p.categories, c],
    }));
  }

  const scoreDest = useCallback((d, usedCategories) => {
    const catMatch = prefs.categories.includes(d.category) ? 1 : 0.15;
    const budgetDist = Math.abs(BUDGET_ORDER.indexOf(d.budget) - BUDGET_ORDER.indexOf(prefs.budget));
    const budgetMatch = budgetDist === 0 ? 1 : budgetDist === 1 ? 0.5 : 0.1;
    const seasonMatch = d.season === prefs.season ? 1 : 0.4;
    const learned = weights[d.category] || 0;
    const repeatPenalty = Math.max(0, 1 - (usedCategories[d.category] || 0) * 0.35);
    const ratingNorm = d.rating / 5;
    return (
      (catMatch * 0.32 + budgetMatch * 0.13 + seasonMatch * 0.1 + learned * 0.25 + ratingNorm * 0.2) * repeatPenalty
    );
  }, [prefs, weights]);

  function generate() {
    const usedCategories = {};
    const itemsPerDay = PACE[prefs.pace];
    const totalSlots = prefs.duration * itemsPerDay;

    const pool = DESTINATIONS.map((d) => ({ ...d, _r: Math.random() * 0.05 + seed * 0 }));
    const selected = [];
    for (let i = 0; i < totalSlots; i++) {
      const ranked = pool
        .filter((d) => !selected.find((s) => s.id === d.id))
        .map((d) => ({ ...d, _score: scoreDest(d, usedCategories) + d._r }))
        .sort((a, b) => b._score - a._score);
      if (ranked.length === 0) break;
      const pick = ranked[0];
      selected.push(pick);
      usedCategories[pick.category] = (usedCategories[pick.category] || 0) + 1;
    }

    // Route optimization: greedy cluster by state so consecutive days stay
    // in the same region, minimizing inter-city travel.
    const stateOrder = [];
    selected.forEach((d) => { if (!stateOrder.includes(d.state)) stateOrder.push(d.state); });
    const clustered = stateOrder.flatMap((st) => selected.filter((d) => d.state === st));

    const days = [];
    for (let i = 0; i < prefs.duration; i++) {
      const dayItems = clustered.slice(i * itemsPerDay, (i + 1) * itemsPerDay);
      if (dayItems.length === 0) continue;
      const majorityState = mostCommon(dayItems.map((d) => d.state));
      const stateSwitch = new Set(dayItems.map((d) => d.state)).size > 1;
      days.push({
        id: nid(),
        label: `Day ${i + 1}`,
        state: majorityState,
        items: dayItems.map((d) => ({ ...d, _why: whyReasons(d, prefs, weights) })),
        foodTip: FOOD_BY_STATE[majorityState],
        stateSwitch,
      });
    }
    setItinerary(days);
    setSeed((s) => s + 1);
  }

  function like(dayId, itemId, category) {
    setProfile((p) => ({ ...p, [category]: (p[category] || 0) + 2 }));
    setLearnFlash(`Learned: you like ${category} more now`);
    setTimeout(() => setLearnFlash(null), 2500);
    setItinerary((prev) =>
      prev.map((d) => (d.id !== dayId ? d : { ...d, items: d.items.map((i) => (i.id === itemId ? { ...i, liked: true } : i)) }))
    );
  }

  function removeItem(dayId, itemId) {
    setItinerary((prev) =>
      prev.map((d) => (d.id !== dayId ? d : { ...d, items: d.items.filter((i) => i.id !== itemId) }))
    );
  }

  function swapItem(dayId, itemId) {
    setItinerary((prev) => {
      const usedIds = prev.flatMap((d) => d.items.map((i) => i.id));
      const day = prev.find((d) => d.id === dayId);
      const current = day.items.find((i) => i.id === itemId);
      const usedCategories = {};
      day.items.forEach((i) => (usedCategories[i.category] = (usedCategories[i.category] || 0) + 1));
      const candidates = DESTINATIONS
        .filter((d) => !usedIds.includes(d.id) && d.state === current.state)
        .map((d) => ({ ...d, _score: scoreDest(d, usedCategories) }))
        .sort((a, b) => b._score - a._score);
      const replacement = candidates[0];
      if (!replacement) return prev;
      return prev.map((d) =>
        d.id !== dayId ? d : {
          ...d,
          items: d.items.map((i) => (i.id === itemId ? { ...replacement, _why: whyReasons(replacement, prefs, weights) } : i)),
        }
      );
    });
  }

  function saveItinerary() {
    if (!itinerary) return;
    setSaved((s) => [{ id: nid(), name: `${prefs.duration}-day trip · ${prefs.categories.join(", ") || "Mixed"}`, days: itinerary, savedAt: "just now" }, ...s]);
  }

  return (
    <div className="ig-root">
      <style>{`
        .ig-root {
          --ink:#1B1F3B; --surface:#242A57; --surface-2:#2E3568; --line:rgba(242,238,228,0.14);
          --marigold:#F5A300; --peacock:#16A398; --vermilion:#E1533D; --sand:#F2EEE4; --muted:#A9AFD9;
          background: radial-gradient(120% 140% at 10% 0%, #232a54 0%, #1B1F3B 55%, #14172e 100%);
          color: var(--sand); font-family:'IBM Plex Sans', system-ui, sans-serif;
          padding: 24px 20px 50px; min-height: 100%; box-sizing: border-box;
        }
        .ig-root * { box-sizing: border-box; }
        .eyebrow { font-family:'IBM Plex Mono', monospace; font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--muted); margin-bottom:6px; }
        h1 { font-family:'Fraunces', Georgia, serif; font-weight:600; font-size: clamp(24px,3.4vw,34px); margin:0 0 20px; }
        h1 em { font-style:italic; color:var(--marigold); font-weight:500; }

        .layout { display:grid; grid-template-columns: 300px 1fr; gap:20px; align-items:start; }
        @media (max-width: 900px) { .layout { grid-template-columns: 1fr; } }

        .panel { background:var(--surface); border:1px solid var(--line); border-radius:8px; padding:18px 20px; margin-bottom:16px; }
        .panel h3 { font-family:'Fraunces', serif; font-size:15.5px; margin:0 0 12px; display:flex; align-items:center; gap:6px; }

        .field { margin-bottom:16px; }
        .field label { font-size:11.5px; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; display:block; margin-bottom:7px; }
        .stepper { display:flex; align-items:center; gap:10px; }
        .stepper button { width:28px; height:28px; border-radius:6px; border:1px solid var(--line); background:var(--surface-2); color:var(--sand); cursor:pointer; }
        .stepper span { font-family:'IBM Plex Mono', monospace; font-size:15px; min-width:40px; text-align:center; }
        select { width:100%; background:var(--surface-2); border:1px solid var(--line); color:var(--sand); padding:8px 10px; border-radius:5px; font-size:13px; font-family:inherit; }
        .pill-row { display:flex; flex-wrap:wrap; gap:6px; }
        .pill { font-size:11.5px; padding:5px 10px; border-radius:16px; border:1px solid var(--line); color:var(--muted); cursor:pointer; background:none; }
        .pill.active { background:var(--peacock); color:#0d1b1a; border-color:var(--peacock); font-weight:600; }

        .gen-btn { width:100%; display:flex; align-items:center; justify-content:center; gap:8px; background:var(--marigold); color:#1B1F3B; border:none; padding:12px; border-radius:7px; font-weight:700; font-size:13.5px; cursor:pointer; }
        .gen-btn:hover { background:#ffb521; }
        .regen-btn { width:100%; display:flex; align-items:center; justify-content:center; gap:7px; background:none; border:1px solid var(--line); color:var(--sand); padding:9px; border-radius:7px; font-size:12.5px; cursor:pointer; margin-top:8px; }

        .weight-row { display:flex; align-items:center; gap:8px; margin-bottom:8px; font-size:12px; }
        .weight-name { width:78px; flex-shrink:0; color:var(--muted); }
        .weight-track { flex:1; height:6px; background:var(--surface-2); border-radius:3px; overflow:hidden; }
        .weight-fill { height:100%; background:linear-gradient(90deg, var(--peacock), var(--marigold)); }
        .weight-pct { width:32px; text-align:right; font-family:'IBM Plex Mono', monospace; color:var(--muted); font-size:11px; }
        .learn-flash { font-size:11.5px; color:var(--peacock); margin-top:8px; display:flex; align-items:center; gap:5px; }

        .empty-state { text-align:center; padding:60px 20px; color:var(--muted); }
        .empty-state svg { color:var(--marigold); margin-bottom:12px; }

        .day-card { background:var(--surface); border:1px solid var(--line); border-radius:8px; padding:16px 18px; margin-bottom:14px; }
        .day-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; }
        .day-head h3 { font-family:'Fraunces', serif; font-size:16.5px; margin:0; }
        .day-region { font-size:11.5px; color:var(--muted); display:flex; align-items:center; gap:4px; }
        .switch-note { font-size:11px; color:var(--vermilion); display:flex; align-items:center; gap:4px; margin-bottom:10px; }
        .food-tip { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--marigold); margin:10px 0 2px; background:rgba(245,163,0,0.1); padding:7px 10px; border-radius:5px; }

        .item-card { border-top:1px solid var(--line); padding:12px 0; }
        .item-top { display:flex; justify-content:space-between; align-items:flex-start; gap:10px; }
        .item-name { font-weight:600; font-size:14.5px; }
        .item-meta { font-size:11.5px; color:var(--muted); display:flex; gap:10px; margin-top:3px; flex-wrap:wrap; }
        .item-meta span { display:flex; align-items:center; gap:3px; }
        .why-row { display:flex; gap:6px; flex-wrap:wrap; margin-top:8px; }
        .why-chip { font-size:10px; background:var(--surface-2); color:var(--muted); padding:3px 8px; border-radius:10px; }
        .item-actions { display:flex; gap:6px; flex-shrink:0; }
        .icon-btn { background:var(--surface-2); border:1px solid var(--line); color:var(--muted); width:28px; height:28px; border-radius:5px; display:flex; align-items:center; justify-content:center; cursor:pointer; }
        .icon-btn:hover { color:var(--sand); }
        .icon-btn.liked { color:var(--marigold); border-color:var(--marigold); }

        .action-row { display:flex; gap:10px; margin-top:16px; }
        .save-btn { display:flex; align-items:center; gap:7px; background:var(--peacock); color:#0d1b1a; border:none; padding:10px 16px; border-radius:6px; font-weight:600; font-size:12.5px; cursor:pointer; }

        .saved-item { font-size:12.5px; padding:9px 0; border-bottom:1px solid var(--line); }
        .saved-item:last-child { border-bottom:none; }
        .saved-name { font-weight:600; }
        .saved-time { color:var(--muted); font-size:11px; }
      `}</style>

      <SectionEyebrow>AI Trip Planner</SectionEyebrow>
      <h1>Your itinerary, <em>generated.</em></h1>

      <div className="layout">
        <div>
          <div className="panel">
            <h3><Sparkles size={15} /> Preferences</h3>
            <div className="field">
              <label>Trip duration</label>
              <div className="stepper">
                <button onClick={() => setPrefs((p) => ({ ...p, duration: Math.max(1, p.duration - 1) }))}>−</button>
                <span>{prefs.duration}d</span>
                <button onClick={() => setPrefs((p) => ({ ...p, duration: Math.min(10, p.duration + 1) }))}>+</button>
              </div>
            </div>
            <div className="field">
              <label>Categories you enjoy</label>
              <div className="pill-row">
                {CATEGORIES.map((c) => (
                  <button key={c} className={`pill ${prefs.categories.includes(c) ? "active" : ""}`} onClick={() => toggleCategory(c)}>{c}</button>
                ))}
              </div>
            </div>
            <div className="field">
              <label>Budget</label>
              <select value={prefs.budget} onChange={(e) => setPrefs((p) => ({ ...p, budget: e.target.value }))}>
                {BUDGET_ORDER.map((b) => <option key={b} value={b}>{b}</option>)}
              </select>
            </div>
            <div className="field">
              <label>Pace</label>
              <select value={prefs.pace} onChange={(e) => setPrefs((p) => ({ ...p, pace: e.target.value }))}>
                {Object.keys(PACE).map((p) => <option key={p} value={p}>{p}</option>)}
              </select>
            </div>
            <div className="field">
              <label>Season</label>
              <select value={prefs.season} onChange={(e) => setPrefs((p) => ({ ...p, season: e.target.value }))}>
                <option>Winter</option><option>Summer</option>
              </select>
            </div>
            <button className="gen-btn" onClick={generate}><Sparkles size={15} /> {itinerary ? "Generate again" : "Generate itinerary"}</button>
            {itinerary && (
              <button className="regen-btn" onClick={generate}><RotateCcw size={13} /> Regenerate with same preferences</button>
            )}
          </div>

          <div className="panel">
            <h3><Brain size={15} /> Your travel profile</h3>
            <div className="panel-desc" style={{ fontSize: 11.5, color: "var(--muted)", marginBottom: 10 }}>
              Learned from bookmarks, likes & past trips
            </div>
            {Object.entries(weights).sort((a, b) => b[1] - a[1]).map(([cat, w]) => (
              <div className="weight-row" key={cat}>
                <div className="weight-name">{cat}</div>
                <div className="weight-track"><div className="weight-fill" style={{ width: `${w * 100}%` }} /></div>
                <div className="weight-pct">{Math.round(w * 100)}%</div>
              </div>
            ))}
            {learnFlash && <div className="learn-flash"><Sparkles size={12} /> {learnFlash}</div>}
          </div>

          {saved.length > 0 && (
            <div className="panel">
              <h3><Save size={15} /> Saved itineraries</h3>
              {saved.map((s) => (
                <div className="saved-item" key={s.id}>
                  <div className="saved-name">{s.name}</div>
                  <div className="saved-time">{s.savedAt}</div>
                </div>
              ))}
            </div>
          )}
        </div>

        <div>
          {!itinerary && (
            <div className="empty-state">
              <Sparkles size={30} />
              <div>Set your preferences and generate a day-wise itinerary.</div>
            </div>
          )}

          {itinerary && itinerary.map((day) => (
            <div className="day-card" key={day.id}>
              <div className="day-head">
                <h3>{day.label}</h3>
                <div className="day-region"><MapPin size={12} /> {day.state}</div>
              </div>
              {day.stateSwitch && (
                <div className="switch-note"><Route size={12} /> This day spans more than one region — expect extra travel time.</div>
              )}
              {day.items.map((item) => (
                <div className="item-card" key={item.id}>
                  <div className="item-top">
                    <div>
                      <div className="item-name">{item.name}</div>
                      <div className="item-meta">
                        <span><Star size={11} /> {item.rating}</span>
                        <span><Clock size={11} /> {item.time}</span>
                        <span><IndianRupee size={11} /> {item.budget}</span>
                      </div>
                      <div className="why-row">
                        {item._why.map((w) => <span className="why-chip" key={w}>{w}</span>)}
                      </div>
                    </div>
                    <div className="item-actions">
                      <button className={`icon-btn ${item.liked ? "liked" : ""}`} onClick={() => like(day.id, item.id, item.category)} title="Like — improves future picks">
                        <ThumbsUp size={13} />
                      </button>
                      <button className="icon-btn" onClick={() => swapItem(day.id, item.id)} title="Swap for alternative">
                        <ChevronDown size={13} />
                      </button>
                      <button className="icon-btn" onClick={() => removeItem(day.id, item.id)} title="Remove">
                        <Trash2 size={13} />
                      </button>
                    </div>
                  </div>
                </div>
              ))}
              {day.foodTip && <div className="food-tip"><Utensils size={13} /> {day.foodTip}</div>}
            </div>
          ))}

          {itinerary && (
            <div className="action-row">
              <button className="save-btn" onClick={saveItinerary}><Save size={14} /> Save itinerary</button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

function mostCommon(arr) {
  const counts = {};
  arr.forEach((v) => (counts[v] = (counts[v] || 0) + 1));
  return Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
}

function whyReasons(d, prefs, weights) {
  const reasons = [];
  if (prefs.categories.includes(d.category)) reasons.push(`Matches ${d.category} preference`);
  if (d.budget === prefs.budget) reasons.push("Within budget");
  if (d.rating >= 4.5) reasons.push("Highly rated");
  if ((weights[d.category] || 0) > 0.2) reasons.push("Learned preference boost");
  if (reasons.length === 0) reasons.push("Good fit for your trip");
  return reasons;
}

function SectionEyebrow({ children }) {
  return <div className="eyebrow">{children}</div>;
}

// ---------------------------------------------------------------------------
// ARCHITECTURE NOTES (for the real implementation)
//
// Scoring: this prototype's scoreDest() is a hand-rolled content-based
// filter — category match + budget distance + season fit + a "learned
// weight" per category + rating, minus a repeat-category penalty for
// diversity. That whole formula is a stand-in for a real hybrid
// recommender: content-based filtering (destination metadata vs. explicit
// preferences) blended with collaborative signal (what similar users with
// similar profiles engaged with), typically combined as a weighted sum or
// a learned re-ranker once there's enough interaction data.
//
// Preference learning: here, "liking" an item just bumps a plain counter
// per category, renormalized into weights. In production this becomes a
// per-user feature vector updated from bookmarks, completed trips, dwell
// time, and search queries — decayed over time so recent behavior matters
// more than a bookmark from a year ago.
//
// Route optimization: destinations are clustered by state and ordered
// greedily, which prevents zig-zagging between regions but is not true
// route optimization. A real version would use actual lat/lng and opening
// hours, solving a constrained variant of TSP (or just nearest-neighbor +
// 2-opt improvement, which is usually good enough at this scale) per day.
//
// Caching: itinerary generation for a given (prefs, profile-snapshot) pair
// is cacheable for a short TTL, since regenerating from an unchanged
// profile should be near-instant rather than recomputing the ranking pass
// on every request.
//
// LLM integration (optional per the issue): an LLM is a reasonable layer
// for turning the ranked stop list into natural-language day summaries and
// food/culture suggestions, but the *ranking and route order* should stay
// deterministic and testable — keep the LLM out of anything that affects
// which destinations get chosen.
// ---------------------------------------------------------------------------